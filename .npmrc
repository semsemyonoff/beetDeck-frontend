# Cap npm's parallel registry connections.
#
# The self-hosted Forgejo CI runs jobs in containers nested behind a double-NAT
# (forgejo-runner-dind on a Docker compose bridge). After the CI host moved to
# Docker 29, the host NAT resets bursts of more than ~10-15 concurrent outbound
# connections. npm's default (maxsockets=15) tripped this: `npm ci` failed with
# "npm error Exit handler never called!" (mass ECONNRESET to registry.npmjs.org),
# which then surfaced downstream as "eslint: not found" / "vitest: not found".
# Capping concurrency keeps installs under the threshold. See CI incident 2026-06-14.
maxsockets=5
fetch-retries=5
fetch-retry-mintimeout=2000
fetch-retry-maxtimeout=60000
